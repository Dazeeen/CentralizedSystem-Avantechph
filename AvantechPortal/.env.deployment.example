DJANGO_ENV=deployment
DJANGO_SECRET_KEY=replace-with-deployment-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=deploy.portal.avantechph.local
DJANGO_ALLOW_LAN_HOSTS=False

DJANGO_DB_ENGINE=sqlite3
DJANGO_DB_NAME=avantech_deployment
DJANGO_DB_FILE=db.sqlite3
DJANGO_DB_TIMEOUT=20
DJANGO_DB_BUSY_TIMEOUT=20000
DJANGO_SQLITE_TRANSACTION_MODE=IMMEDIATE

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_TIMEOUT_SECONDS=1800
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
