DJANGO_ENV=production
DJANGO_SECRET_KEY=replace-with-long-random-production-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=portal.avantechph.local,portal.avantechph.com
DJANGO_ALLOW_LAN_HOSTS=False

DJANGO_DB_ENGINE=postgresql
DJANGO_DB_NAME=avantech
DJANGO_DB_USER=avantech_user
DJANGO_DB_PASSWORD=replace-with-strong-db-password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=120
DJANGO_DB_CONNECT_TIMEOUT=10

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_TIMEOUT_SECONDS=1800
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=replace-with-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@portal.avantechph.com
